
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Core profile information for all institutional users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "Institutional email address (@neu.edu.ph)." },
        "name": { "type": "string", "description": "Full name of the user." },
        "role": { "type": "string", "enum": ["admin", "visitor"], "description": "System access level." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of profile creation." }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    },
    "UserSession": {
      "title": "UserSession",
      "description": "Represents an active user session in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "loginTime": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" }
      },
      "required": ["uid", "email", "name", "role", "loginTime"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Central collection for all registered institutional users."
    },
    "/sessions/{sessionId}": {
      "schema": "UserSession",
      "description": "Active user sessions for real-time monitoring."
    }
  }
}
