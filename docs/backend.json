
{
  "entities": {
    "AdminProfile": {
      "title": "AdminProfile",
      "description": "Profile information for system administrators.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "Institutional email address." },
        "name": { "type": "string", "description": "Full name of the administrator." },
        "role": { "type": "string", "enum": ["Admin"], "description": "User role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of account creation." }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": "AdminProfile",
      "description": "Collection of administrator profiles."
    }
  }
}
